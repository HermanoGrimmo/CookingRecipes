{% extends 'base.html.twig' %}

{% block title %}E-Mail gesendet - CookingRecipes{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <span class="auth-icon">📧</span>
            <h1 class="auth-title">E-Mail gesendet!</h1>
        </div>

        <p class="auth-message">
            Falls deine E-Mail-Adresse registriert ist, haben wir dir einen Link zum Zurücksetzen deines Passworts gesendet.
            Bitte schau auch in deinem Spam-Ordner nach.
        </p>

        <p class="auth-message">
            Der Link ist <strong>60 Minuten</strong> gültig.
        </p>

        <p class="auth-link">
            <a href="{{ path('security_login') }}" class="btn btn-secondary">Zurück zur Anmeldung</a>
        </p>
    </div>
</div>
{% endblock %}
