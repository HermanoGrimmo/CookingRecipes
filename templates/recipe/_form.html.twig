{{ form_start(form, {attr: {class: 'recipe-form', novalidate: 'novalidate'}}) }}

{# Flash-Nachrichten #}
{% for message in app.flashes('error') %}
    <div class="flash flash-error">{{ message }}</div>
{% endfor %}

{# ── Basisinformationen ───────────────────────────────────────── #}
<section class="form-section">
    <h2 class="form-section-title">
        <span class="section-icon">📝</span> Basisinformationen
    </h2>
    <div class="form-grid">
        <div class="form-group form-col-full">
            {{ form_label(form.title) }}
            {{ form_widget(form.title) }}
            {{ form_errors(form.title) }}
        </div>
        <div class="form-group form-col-full">
            {{ form_label(form.description) }}
            {{ form_widget(form.description) }}
            {{ form_errors(form.description) }}
        </div>
        <div class="form-group">
            {{ form_label(form.imagePath) }}
            {{ form_widget(form.imagePath) }}
            {{ form_errors(form.imagePath) }}
        </div>
    </div>
</section>

{# ── Eckdaten ─────────────────────────────────────────────────── #}
<section class="form-section">
    <h2 class="form-section-title">
        <span class="section-icon">⏱️</span> Eckdaten
    </h2>
    <div class="form-grid form-grid-4">
        <div class="form-group">
            {{ form_label(form.servings) }}
            {{ form_widget(form.servings) }}
            {{ form_errors(form.servings) }}
        </div>
        <div class="form-group">
            {{ form_label(form.prepTime) }}
            {{ form_widget(form.prepTime) }}
            {{ form_errors(form.prepTime) }}
        </div>
        <div class="form-group">
            {{ form_label(form.cookTime) }}
            {{ form_widget(form.cookTime) }}
            {{ form_errors(form.cookTime) }}
        </div>
        <div class="form-group">
            {{ form_label(form.difficulty) }}
            {{ form_widget(form.difficulty) }}
            {{ form_errors(form.difficulty) }}
        </div>
    </div>
</section>

{# ── Zutaten ──────────────────────────────────────────────────── #}
<section class="form-section">
    <h2 class="form-section-title">
        <span class="section-icon">🥕</span> Zutaten
    </h2>

    <div class="collection-header">
        <div class="collection-col-labels">
            <span>Menge</span>
            <span>Einheit</span>
            <span>Zutat</span>
            <span>Gruppe</span>
            <span></span>
        </div>
    </div>

    <div class="collection-list" id="ingredients-list"
         data-prototype="{{ form_widget(form.ingredients.vars.prototype)|e('html_attr') }}"
         data-index="{{ form.ingredients|length }}">
        {% for ingredientForm in form.ingredients %}
            <div class="collection-row">
                {{ form_widget(ingredientForm.amount) }}
                {{ form_widget(ingredientForm.unit) }}
                {{ form_widget(ingredientForm.name) }}
                {{ form_widget(ingredientForm.groupName) }}
                <button type="button" class="btn-remove-row" title="Zutat entfernen">✕</button>
            </div>
        {% endfor %}
    </div>

    <button type="button" class="btn-add-row" data-target="ingredients-list">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="icon"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Zutat hinzufügen
    </button>
</section>

{# ── Zubereitungsschritte ─────────────────────────────────────── #}
<section class="form-section">
    <h2 class="form-section-title">
        <span class="section-icon">👨‍🍳</span> Zubereitungsschritte
    </h2>

    <div class="steps-collection" id="steps-list"
         data-prototype="{{ form_widget(form.steps.vars.prototype)|e('html_attr') }}"
         data-index="{{ form.steps|length }}">
        {% for stepForm in form.steps %}
            <div class="step-collection-row">
                <div class="step-col-number">{{ loop.index }}</div>
                <div class="step-col-fields">
                    <div class="form-group">
                        {{ form_widget(stepForm.title) }}
                    </div>
                    <div class="form-group">
                        {{ form_widget(stepForm.description) }}
                    </div>
                </div>
                <button type="button" class="btn-remove-row" title="Schritt entfernen">✕</button>
            </div>
        {% endfor %}
    </div>

    <button type="button" class="btn-add-row" data-target="steps-list">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="icon"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Schritt hinzufügen
    </button>
</section>

{# ── Aktionen ─────────────────────────────────────────────────── #}
<div class="form-actions">
    <a href="{{ back_url }}" class="btn btn-secondary">Abbrechen</a>
    <button type="submit" class="btn btn-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v14a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        {{ submit_label }}
    </button>
</div>

{{ form_end(form) }}
