<script>
document.addEventListener('DOMContentLoaded', () => {

    // ── Prototype-basiertes Hinzufügen von Zutaten/Schritten ────
    document.querySelectorAll('.btn-add-row').forEach(btn => {
        btn.addEventListener('click', () => {
            const listId  = btn.dataset.target;
            const list    = document.getElementById(listId);
            const isSteps = list.classList.contains('steps-collection');

            let index    = parseInt(list.dataset.index, 10);
            let proto    = list.dataset.prototype;

            // Platzhalterindex ersetzen
            proto = proto.replaceAll('__ingredient_index__', index)
                         .replaceAll('__step_index__', index);

            // Prototype-HTML in temporärem Element parsen
            const temp = document.createElement('div');
            temp.innerHTML = proto;

            const wrapper = document.createElement('div');
            wrapper.className = isSteps ? 'step-collection-row' : 'collection-row';

            if (isSteps) {
                // Schrittnummer-Badge einfügen
                const badge = document.createElement('div');
                badge.className = 'step-col-number';
                badge.textContent = list.querySelectorAll('.step-collection-row').length + 1;
                wrapper.appendChild(badge);

                // Felder in step-col-fields wrappen
                const fieldsDiv = document.createElement('div');
                fieldsDiv.className = 'step-col-fields';
                [...temp.querySelectorAll('input, textarea')].forEach(el => {
                    const grp = document.createElement('div');
                    grp.className = 'form-group';
                    el.classList.add('input');
                    grp.appendChild(el);
                    fieldsDiv.appendChild(grp);
                });
                wrapper.appendChild(fieldsDiv);

                // Entfernen-Button anhängen
                const removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.className = 'btn-remove-row';
                removeBtn.title = 'Schritt entfernen';
                removeBtn.textContent = '✕';
                wrapper.appendChild(removeBtn);
            } else {
                // Zutaten: Inputs direkt in die Grid-Zeile extrahieren
                const inputs = [...temp.querySelectorAll('input')];
                const classes = ['input input-amount', 'input input-unit', 'input input-name', 'input input-group'];
                inputs.forEach((inp, i) => {
                    inp.className = classes[i] ?? 'input';
                    wrapper.appendChild(inp);
                });

                // Entfernen-Button
                const removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.className = 'btn-remove-row';
                removeBtn.title = 'Zutat entfernen';
                removeBtn.textContent = '✕';
                wrapper.appendChild(removeBtn);
            }

            list.appendChild(wrapper);
            list.dataset.index = index + 1;
            updateStepNumbers(list);
        });
    });

    // ── Entfernen-Buttons (delegiert, gilt auch für neue Zeilen) ─
    document.addEventListener('click', e => {
        if (!e.target.matches('.btn-remove-row')) return;
        const row  = e.target.closest('.collection-row, .step-collection-row');
        const list = row?.closest('.collection-list, .steps-collection');
        row?.remove();
        if (list) updateStepNumbers(list);
    });

    // ── Schrittnummern nach Entfernen neu setzen ─────────────────
    function updateStepNumbers(list) {
        list.querySelectorAll('.step-col-number').forEach((el, i) => {
            el.textContent = i + 1;
        });
    }

    // ── Bild-URL Vorschau ─────────────────────────────────────────
    const imageInput = document.querySelector('input[name$="[imagePath]"]');
    if (imageInput) {
        const preview = document.createElement('div');
        preview.className = 'image-preview';
        imageInput.after(preview);

        const render = () => {
            const url = imageInput.value.trim();
            preview.innerHTML = url
                ? `<img src="${url}" alt="Vorschau" onerror="this.style.display='none'">`
                : '';
        };
        render();
        imageInput.addEventListener('input', render);
    }
});
</script>
