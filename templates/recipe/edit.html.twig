{% extends 'base.html.twig' %}

{% block title %}{{ recipe.title }} bearbeiten – CookingRecipes{% endblock %}

{% block body %}
<div class="form-page">
    <div class="container">
        <div class="form-page-header">
            <a href="{{ path('recipe_show', {id: recipe.id}) }}" class="back-link">
                <svg width="18" height="18" class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Zurück zum Rezept
            </a>
            <h1 class="form-page-title">Rezept bearbeiten</h1>
            <p class="form-page-subtitle">Ändere die Details von <strong>{{ recipe.title }}</strong>.</p>
        </div>

        <twig:RecipeForm
            :initialFormData="recipe"
            backUrl="{{ path('recipe_show', {id: recipe.id}) }}"
            submitLabel="Änderungen speichern"
        />

        {# Rezept löschen #}
        <div class="danger-zone">
            <h3>Gefahrenzone</h3>
            <p>Das Löschen eines Rezepts kann nicht rückgängig gemacht werden.</p>
            <form method="post" action="{{ path('recipe_delete', {id: recipe.id}) }}"
                  onsubmit="return confirm('Rezept wirklich unwiderruflich löschen?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ recipe.id) }}">
                <button type="submit" class="btn btn-danger">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
                    Rezept löschen
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block body_js %}
    {{ include('recipe/_image_preview_js.html.twig') }}
{% endblock %}
